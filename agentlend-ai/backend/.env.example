APP_NAME=AgentLend AI
DEBUG=false

# Render Postgres connection string
# Supports both postgres:// and postgresql://
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentlend

# Comma-separated origins. Add your Vercel domain here in production.
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

WDK_API_KEY=
WDK_BASE_URL=https://api.wdk.tether.to/v1

SEPOLIA_RPC_URL=https://rpc.sepolia.org
ETHERSCAN_API_KEY=
ETHERSCAN_BASE_URL=https://api-sepolia.etherscan.io/api
CHAIN_ID=11155111

TREASURY_WALLET_ADDRESS=
TREASURY_PRIVATE_KEY=
TOKEN_CONTRACT_ADDRESS=
TOKEN_DECIMALS=6

AGENT_LOOP_INTERVAL_SECONDS=120
REPAYMENT_MONITOR_INTERVAL_SECONDS=60

MAX_LOAN_AMOUNT=1000
MIN_LOAN_AMOUNT=10
DEFAULT_LOAN_DURATION_DAYS=30

COLD_START_ENABLED=true
COLD_START_MAX_LOAN_AMOUNT=10
COLD_START_MAX_WALLET_AGE_DAYS=7
COLD_START_MAX_TX_COUNT=2
COLD_START_NEUTRAL_REPAYMENT_RATE=0.5
COLD_START_BASE_CREDIT_SCORE=400
COLD_START_RISK_SCORE=58
COLD_START_INTEREST_RATE=12
